{
  "tasks": {
    "dev": "deno run -A npm:vite",
    "typecheck": "deno check src/main.tsx",
    "build": "deno check src/main.tsx && deno run -A npm:vite build",
    "serve": "deno run build",
    "signal": "deno run --allow-net --allow-env signaling-server.ts",
    "lint": "deno run -A npm:eslint ."
  },
  "compilerOptions": {
    "types": [
        "react",
        "react-dom",
        "@types/react"
    ],
    "lib": [
        "dom",
        "dom.iterable",
        "deno.ns"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
